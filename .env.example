# DSN async SQLAlchemy (postgresql+asyncpg://…)
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/payments
# Строка подключения AMQP
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# Статический ключ для заголовка X-API-Key
API_KEY=dev-secret-api-key-change-me
# Пауза relay, когда outbox пуст (секунды)
OUTBOX_POLL_INTERVAL_SEC=0.75
# Число попыток доставки webhook
WEBHOOK_MAX_ATTEMPTS=3
# База экспоненциальной задержки webhook (секунды)
WEBHOOK_BACKOFF_BASE_SEC=1.0
# Попыток обработки сообщения consumer до отправки в DLQ
CONSUMER_MAX_PROCESS_RETRIES=3
